# =============================================================================
# JARVIS Voice PE — Secrets Template
# =============================================================================
# Copia questo file come secrets.yaml e personalizza i valori.
#
#   cp secrets.yaml.example secrets.yaml
#   nano secrets.yaml
#
# NON committare secrets.yaml nel repository!
# =============================================================================

# WiFi
wifi_ssid: "YourWiFiSSID"
wifi_password: "YourWiFiPassword"

# JARVIS Wakeword Server (LAN)
jarvis_server_url: "ws://wakeword-server.local:8200/ws/audio"

# Device token (opzionale, lascia vuoto se non usi autenticazione)
jarvis_device_token: ""
